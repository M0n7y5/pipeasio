{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "wineasio: regsvr32 in test prefix",
            "type": "shell",
            "command": "env WINEPREFIX=${env:HOME}/.wine-test wine regsvr32 ${workspaceFolder}/build/wineasio64.dll.so",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "wineasio: tail wine debug log",
            "type": "shell",
            "command": "tail -F ${env:HOME}/.wine-test/wine.log",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "wineasio: install to /usr (sudo)",
            "type": "shell",
            "command": "sudo cmake --install ${workspaceFolder}/build --prefix /usr",
            "dependsOn": "CMake: build",
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        }
    ]
}
